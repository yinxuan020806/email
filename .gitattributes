# Force LF line endings for shell scripts and Dockerfiles.
# Critical: these files run inside Linux containers; CRLF will cause
#   /entrypoint.sh: No such file or directory
# (bash treats trailing \r as part of the script path).

*.sh         text eol=lf
*.bash       text eol=lf
Dockerfile   text eol=lf
*.Dockerfile text eol=lf
